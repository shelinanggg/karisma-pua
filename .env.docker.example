# Salin menjadi .env.docker. Jangan commit .env.docker.

# Lokal HTTP: development
# Server dengan HTTPS: production
NODE_ENV=development
TZ=Asia/Jakarta
APP_PORT=8080

DB_NAME=karisma
DB_USER=karisma_user
DB_PASSWORD=ganti_dengan_password_database_yang_kuat

JWT_SECRET=ganti_dengan_secret_acak_minimal_64_karakter

# Lokal:
CORS_ORIGINS=http://localhost:8080

# Tetap false kecuali id_periode_skp=1 sudah diverifikasi benar.
ALLOW_HARDCODED_PERIOD_ID=false

# Contoh server:
# CORS_ORIGINS=https://karisma.example.go.id
